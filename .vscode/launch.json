{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Pytest Async",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "tests/test_db_accessors.py::test_run_sql",
                "-v",
                "-s",
                "-x",
                "--color=yes",
                "--asyncio-mode=auto"
            ],
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Python Debugger: aio",
            "type": "debugpy",
            "request": "launch",
            "module": "aio.__main__",
            "jinja": true,
            "justMyCode": true
        }
    ]
}